APP_NAME=TerraRisk Credit Intelligence API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True

# PostgreSQL + PostGIS connection (async driver). Matches docker/docker-compose.yml
# defaults for local dev — change the credentials before any shared/deployed use.
# Host port is 5433, not Postgres's usual 5432 — some developer machines
# already have another PostgreSQL instance bound to 127.0.0.1:5432, which
# silently intercepts "localhost" connections rather than erroring. Adjust
# if 5433 is also taken locally, just keep this and docker-compose.yml in sync.
DATABASE_URL=postgresql+asyncpg://terrarisk:terrarisk@localhost:5433/terrarisk

# Bearer-token signing secret. Generate your own — never reuse this example
# value: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=replace-with-a-generated-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

# Google Earth Engine — see docs/DECISIONS.md for the project/service-account
# setup walkthrough. GEE_SERVICE_ACCOUNT_JSON_PATH points at a local key file
# that is never committed (already covered by .gitignore's `.env*` rule, but
# keep the key itself outside the repo entirely, e.g. in a secrets directory).
GEE_PROJECT_ID=terrarisk-platform
GEE_SERVICE_ACCOUNT_JSON_PATH=/absolute/path/to/terrarisk-gee-service-account.json